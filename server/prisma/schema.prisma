generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum Stage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum SpecialBetType {
  CHAMPION
  TOP_SCORER
  TOP_ASSISTS
}

model User {
  id          Int        @id @default(autoincrement())
  username    String     @unique
  email       String     @unique
  password    String
  role        Role       @default(USER)
  status      UserStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  matchBets      MatchBet[]
  specialBets    SpecialBet[]
  bonusLogs      BonusLog[]
  rankSnapshots  RankSnapshot[]
}

model BonusLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String   // e.g. "R1_BONUS", "UNIQUE_EXACT_<matchId>"
  createdAt DateTime @default(now())
}

model RankSnapshot {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String   // e.g. "MD 1", "MD 2", "MD 3", "R32", "R16", "QF", "SF", "Final"
  rank        Int
  totalPoints Int
  createdAt   DateTime @default(now())

  @@unique([userId, label])
}

model Team {
  id           Int    @id @default(autoincrement())
  externalId   Int?   @unique // API-Football team ID
  name         String @unique
  code         String @unique // e.g. "BRA", "ARG"
  group        String // "A", "B", ... "L"
  flagUrl      String?

  homeMatches  Match[] @relation("HomeTeam")
  awayMatches  Match[] @relation("AwayTeam")
  specialBets  SpecialBet[]
  players      Player[]
}

model Player {
  id         Int     @id @default(autoincrement())
  externalId Int?    @unique
  name       String
  position   String?
  teamId     Int
  team       Team    @relation(fields: [teamId], references: [id])
}

model Match {
  id           Int         @id @default(autoincrement())
  externalId   Int?        @unique // API-Football fixture ID
  homeTeamId   Int
  awayTeamId   Int
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  stage        Stage
  groupRound   Int?        // 1, 2, or 3 — only for GROUP stage
  matchDate    DateTime
  venue        String?
  homeScore    Int?        // null until match is finished
  awayScore    Int?
  bracketSlot  Int?        // 1–16 for R32, 1–8 for R16, etc. — admin-assigned
  status       MatchStatus @default(UPCOMING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  bets         MatchBet[]
}

model SyncLog {
  id          Int      @id @default(autoincrement())
  syncedAt    DateTime @default(now())
  matchesUpdated Int   @default(0)
  newlyScored    Int   @default(0)
  error       String?
}

model MatchBet {
  id             Int      @id @default(autoincrement())
  userId         Int
  matchId        Int
  predictedHome  Int
  predictedAway  Int
  pointsAwarded  Int?     // null until match is scored
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model SpecialBet {
  id        Int            @id @default(autoincrement())
  userId    Int
  type      SpecialBetType
  teamId    Int?           // for CHAMPION
  playerId  Int?           // for TOP_SCORER / TOP_ASSISTS (kept for future player data)
  playerName String?       // free-text player name entry for now

  pointsAwarded Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [teamId], references: [id])

  @@unique([userId, type])
}
