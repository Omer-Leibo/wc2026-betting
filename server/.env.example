# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically by Railway when you add a PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-long-random-secret-here"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (set after Vercel deploy)
CLIENT_URL="https://wc2026.yourdomain.com"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Football data API (live scores) ──────────────────────────────────────────
FOOTBALL_API_KEY="your-api-key"
FOOTBALL_API_BASE_URL="https://api.football-data.org/v4"
COMPETITION_CODE="WC"
