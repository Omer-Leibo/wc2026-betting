DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wc2026"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3001
NODE_ENV=development

# football-data.org — FREE tier includes FIFA World Cup, 10 req/min, no daily cap
# Register instantly (no credit card): https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_football_data_key_here

# Sync interval in milliseconds (default: 5 minutes)
SYNC_INTERVAL_MS=300000

# TEST MODE — temporarily override the competition for end-to-end testing.
# Set to a free-tier competition code (e.g. SA = Serie A, PL = Premier League)
# to test auto-sync and scoring with real live games before the WC starts.
# Remove this line (or set to WC) to go back to normal World Cup mode.
# FOOTBALL_API_COMPETITION=SA
